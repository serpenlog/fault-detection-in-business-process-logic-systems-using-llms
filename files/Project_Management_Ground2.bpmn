    <sequenceFlow id="Flow_19" sourceRef="AdjustPlan" targetRef="ProjectMonitoringAndReporting" />
    <task id="ProjectHandoverAndClosure" name="Project Handover and Closure">
      <incoming>Flow_17</incoming>
      <outgoing>Flow_20</outgoing>
    </task>
    <endEvent id="EndEvent_1" name="End">
      <incoming>Flow_20</incoming>
    </endEvent>
    <sequenceFlow id="Flow_1" sourceRef="StartEvent_1" targetRef="ProjectInitiation" />

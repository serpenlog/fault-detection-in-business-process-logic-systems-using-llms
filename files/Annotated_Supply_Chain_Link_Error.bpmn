        <ns0:waypoint xmlns:ns0="http://www.omg.org/spec/DD/20100524/DI" x="350" y="118" />
      <ns0:BPMNShape xmlns:ns0="http://www.omg.org/spec/BPMN/20100524/DI" xmlns:ns1="http://www.omg.org/spec/DD/20100524/DC" id="EndEvent_1_di" bpmnElement="EndEvent_1">
        <ns1:Bounds x="400" y="100" width="36" height="36" />
      </ns0:BPMNShape>
    <ns0:Bounds xmlns:ns0="http://www.omg.org/spec/DD/20100524/DC" x="400" y="100" width="36" height="36" />
      
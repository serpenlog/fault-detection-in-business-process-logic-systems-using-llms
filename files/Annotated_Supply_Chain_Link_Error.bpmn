        <ns2:waypoint x="200" y="118" />
      </ns0:BPMNEdge>
      
      
      <ns0:BPMNEdge id="Flow_2_di" bpmnElement="Flow_2">
        <ns2:waypoint x="300" y="118" />
        <ns2:waypoint x="350" y="118" />
      </ns0:BPMNEdge>
      
      <ns0:BPMNShape id="EndEvent_1_di" bpmnElement="EndEvent_1">
        <ns1:Bounds x="400" y="100" width="36" height="36" />
      </ns0:BPMNShape>
    </ns0:BPMNPlane>
  <ns0:BPMNShape xmlns:ns0="http://www.omg.org/spec/BPMN/20100524/DI" xmlns:ns1="http://www.omg.org/spec/DD/20100524/DC" id="StartEvent_1_di" bpmnElement="StartEvent_1">
        <ns1:Bounds x="100" y="100" width="36" height="36" />
      </ns0:BPMNShape>
      <ns0:Bounds xmlns:ns0="http://www.omg.org/spec/DD/20100524/DC" x="100" y="100" width="36" height="36" />
      <ns0:BPMNShape xmlns:ns0="http://www.omg.org/spec/BPMN/20100524/DI" xmlns:ns1="http://www.omg.org/spec/DD/20100524/DC" id="Activity_1_di" bpmnElement="Activity_1">
        <ns1:Bounds x="200" y="100" width="100" height="80" />
      </ns0:BPMNShape>
      
      
      <ns0:Bounds xmlns:ns0="http://www.omg.org/spec/DD/20100524/DC" x="200" y="100" width="100" height="80" />
      <ns0:BPMNShape xmlns:ns0="http://www.omg.org/spec/BPMN/20100524/DI" xmlns:ns1="http://www.omg.org/spec/DD/20100524/DC" id="ExclusiveGateway_1_di" bpmnElement="ExclusiveGateway_1">
        <ns1:Bounds x="350" y="110" width="50" height="50" />
      </ns0:BPMNShape>
      
      
      <ns0:Bounds xmlns:ns0="http://www.omg.org/spec/DD/20100524/DC" x="350" y="110" width="50" height="50" />
      <ns0:BPMNEdge xmlns:ns0="http://www.omg.org/spec/BPMN/20100524/DI" xmlns:ns1="http://www.omg.org/spec/DD/20100524/DI" id="Flow_1_di" bpmnElement="Flow_1">
        <ns1:waypoint x="136" y="118" />
        <ns1:waypoint x="200" y="118" />
      </ns0:BPMNEdge>
      
      
      <ns0:waypoint xmlns:ns0="http://www.omg.org/spec/DD/20100524/DI" x="136" y="118" />
        <ns0:waypoint xmlns:ns0="http://www.omg.org/spec/DD/20100524/DI" x="200" y="118" />
